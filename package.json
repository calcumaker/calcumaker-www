{
  "name": "calcumaker-www",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Marketing site for Calcumaker 16 (calcumaker.co). Static HTML/CSS/JS — no build step.",
  "scripts": {
    "serve": "python3 -m http.server 8080",
    "lint": "npm run lint:css && npm run lint:js",
    "lint:css": "stylelint \"assets/**/*.css\"",
    "lint:js": "eslint . --max-warnings 0",
    "lint:fix": "stylelint \"assets/**/*.css\" --fix && eslint . --fix",
    "verify": "node scripts/verify.mjs",
    "icons": "node scripts/render-icons.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "playwright": "^1.61.1",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0"
  }
}
